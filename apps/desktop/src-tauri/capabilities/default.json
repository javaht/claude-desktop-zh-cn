{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Claude-Zh 桌面应用默认权限",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:path:default",
    "core:resources:default",
    "core:menu:default",
    "core:image:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/javaht/*" },
        { "url": "https://github.com/javaht/claude-desktop-zh-cn" },
        { "url": "https://github.com/javaht/claude-desktop-zh-cn/issues" }
      ]
    }
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Desktop 中文补丁",
  "version": "0.1.2",
  "identifier": "cn.javaht.claude-desktop-zh-cn-rs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Desktop 中文补丁",
        "width": 1180,
        "height": 820,
        "minWidth": 940,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "hardenedRuntime": false
    },
    "resources": {
      "../../../resources": "resources"
    }
  }
}
